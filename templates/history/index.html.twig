{% extends 'base.html.twig' %}

{% block title %}Audit Logs - LogiKit{% endblock %}

{% block body %}
<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Audit Logs</h1>
    <p class="text-gray-500">Historique complet des actions sur le matériel</p>
</div>

<div class="bg-white rounded-xl shadow p-6">
    <table class="w-full">
        <thead>
            <tr class="text-left text-gray-400 text-sm border-b">
                <th class="pb-3">DATE</th>
                <th class="pb-3">UTILISATEUR</th>
                <th class="pb-3">MATÉRIEL</th>
                <th class="pb-3">ACTION</th>
            </tr>
        </thead>
        <tbody>
            {% for history in histories %}
            <tr class="border-b hover:bg-gray-50">
                <td class="py-4 text-gray-500 text-sm">{{ history.date|date('d/m/Y H:i') }}</td>
                <td class="py-4">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-full bg-gray-900 text-white flex items-center justify-center text-xs font-bold">
                            {% if history.user %}
                                {{ history.user.prenom|first }}{{ history.user.nom|first }}
                            {% else %}
                                ?
                            {% endif %}
                        </div>
                        <span>{{ history.user ? history.user.prenom ~ ' ' ~ history.user.nom : '-' }}</span>
                    </div>
                </td>
                <td class="py-4 font-medium">{{ history.asset ? history.asset.brand ~ ' ' ~ history.asset.model : '-' }}</td>
                <td class="py-4">
                    <span class="{% if 'Attribution' in history.action %}bg-green-100 text-green-800{% elseif 'maintenance' in history.action %}bg-orange-100 text-orange-800{% elseif 'assigned' in history.action %}bg-blue-100 text-blue-800{% else %}bg-gray-100 text-gray-800{% endif %} px-2 py-1 rounded text-sm">
                        {{ history.action }}
                    </span>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4" class="text-center text-gray-400 py-8">
                    Aucun historique pour le moment
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}