{% extends 'base.html.twig' %}

{% block title %}Maintenance - LogiKit{% endblock %}

{% block body %}
<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Matériel en maintenance</h1>
    <p class="text-gray-500">Liste des équipements actuellement en réparation</p>
</div>

{% if assets|length > 0 %}
<div class="bg-orange-50 border-l-4 border-orange-500 text-orange-700 px-6 py-4 rounded-xl mb-6 flex items-center gap-3">
    <span class="text-2xl">🔧</span>
    <div>
        <p class="font-bold">{{ assets|length }} équipement(s) en maintenance</p>
        <p class="text-sm">Ces équipements sont indisponibles jusqu'à la fin de leur maintenance.</p>
    </div>
</div>
{% endif %}

<div class="bg-white rounded-xl shadow p-6">
    <table class="w-full">
        <thead>
            <tr class="text-left text-gray-400 text-sm border-b">
                <th class="pb-3">MARQUE / MODÈLE</th>
                <th class="pb-3">NUMÉRO DE SÉRIE</th>
                <th class="pb-3">CATÉGORIE</th>
                <th class="pb-3">DATE CRÉATION</th>
                <th class="pb-3">ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            {% for asset in assets %}
            <tr class="border-b hover:bg-gray-50">
                <td class="py-4 font-medium">{{ asset.brand }} {{ asset.model }}</td>
                <td class="py-4">
                    <span class="bg-gray-100 px-2 py-1 rounded text-sm">
                        {{ asset.serialNumber }}
                    </span>
                </td>
                <td class="py-4">{{ asset.category ?? 'Non défini' }}</td>
                <td class="py-4 text-gray-500">{{ asset.createdAt ? asset.createdAt|date('d/m/Y') : '' }}</td>
                <td class="py-4">
                    <a href="{{ path('app_asset_show', {'id': asset.id}) }}" 
                       class="text-blue-600 hover:text-blue-800 mr-3">Voir</a>
                    <a href="{{ path('app_asset_transition', {'id': asset.id, 'transition': 'from_maintenance'}) }}" 
                       class="bg-green-500 text-white px-3 py-1 rounded text-sm hover:bg-green-600">
                        Disponible
                    </a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="text-center text-gray-400 py-8">
                    Aucun équipement en maintenance
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="mt-4">
    <a href="{{ path('app_asset_index') }}" class="text-gray-600 hover:text-gray-800">
        ← Retour à la liste
    </a>
</div>
{% endblock %}