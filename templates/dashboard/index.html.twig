{% extends 'base.html.twig' %}

{% block title %}Dashboard - LogiKit{% endblock %}

{% block body %}
<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Tableau de bord</h1>
        <p class="text-gray-500">Bienvenue, voici un aperçu de votre parc informatique</p>
    </div>
    <a href="/assignment/new" class="bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-700">
        + Nouvelle attribution
    </a>
</div>

{# Cards stats #}
<div class="grid grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow hover:shadow-md transition">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Total Matériel</p>
                <p class="text-3xl font-bold mt-2">{{ totalAssets }}</p>
                <p class="text-gray-400 text-sm mt-1">Parc informatique</p>
            </div>
            <span class="text-3xl">💻</span>
        </div>
    </div>
    <div class="bg-white rounded-xl p-6 shadow hover:shadow-md transition">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Disponibles</p>
                <p class="text-3xl font-bold mt-2 text-green-500">{{ availableAssets }}</p>
                <p class="text-green-400 text-sm mt-1">Prêts à l'attribution</p>
            </div>
            <span class="text-3xl">✅</span>
        </div>
    </div>
    <div class="bg-white rounded-xl p-6 shadow hover:shadow-md transition">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">En maintenance</p>
                <p class="text-3xl font-bold mt-2 text-orange-500">{{ underRepair }}</p>
                <p class="text-orange-400 text-sm mt-1">En réparation</p>
            </div>
            <span class="text-3xl">🔧</span>
        </div>
    </div>
    <div class="bg-white rounded-xl p-6 shadow hover:shadow-md transition">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Alertes stock</p>
                <p class="text-3xl font-bold mt-2 text-red-500">{{ stockAlerts }}</p>
                <p class="text-red-400 text-sm mt-1">Stock faible</p>
            </div>
            <span class="text-3xl">⚠️</span>
        </div>
    </div>
</div>

{# Raccourcis rapides #}
<div class="grid grid-cols-4 gap-4 mb-8">
    <a href="/asset" class="bg-gray-800 text-white rounded-xl p-4 text-center hover:bg-gray-700 transition">
        <p class="text-2xl mb-1">📦</p>
        <p class="text-sm font-medium">Voir les assets</p>
    </a>
    <a href="/asset/maintenance" class="bg-orange-500 text-white rounded-xl p-4 text-center hover:bg-orange-600 transition">
        <p class="text-2xl mb-1">🔧</p>
        <p class="text-sm font-medium">Maintenance</p>
    </a>
    <a href="/consumable" class="bg-blue-600 text-white rounded-xl p-4 text-center hover:bg-blue-700 transition">
        <p class="text-2xl mb-1">🖱️</p>
        <p class="text-sm font-medium">Consommables</p>
    </a>
    <a href="/history" class="bg-purple-600 text-white rounded-xl p-4 text-center hover:bg-purple-700 transition">
        <p class="text-2xl mb-1">📋</p>
        <p class="text-sm font-medium">Audit Logs</p>
    </a>
</div>

{# Attributions récentes #}
<div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-bold mb-1">Attributions récentes</h2>
    <p class="text-gray-500 text-sm mb-4">Dernières attributions de matériel</p>
    <table class="w-full">
        <thead>
            <tr class="text-left text-gray-400 text-sm border-b">
                <th class="pb-3">EMPLOYÉ</th>
                <th class="pb-3">MATÉRIEL</th>
                <th class="pb-3">NUMÉRO DE SÉRIE</th>
                <th class="pb-3">DATE</th>
                <th class="pb-3">ACTION</th>
            </tr>
        </thead>
        <tbody>
            {% for assignment in recentAssignments %}
            <tr class="border-b hover:bg-gray-50">
                <td class="py-4">{{ assignment.user.prenom }} {{ assignment.user.nom }}</td>
                <td class="py-4">{{ assignment.asset ? assignment.asset.model : 'Consommable' }}</td>
                <td class="py-4">
                    <span class="bg-gray-100 px-2 py-1 rounded text-sm">
                        {{ assignment.asset ? assignment.asset.serialNumber : '-' }}
                    </span>
                </td>
                <td class="py-4">{{ assignment.assignedAt|date('d/m/Y') }}</td>
                <td class="py-4">
                   <a href="{{ path('app_assignment_pdf', {'id': assignment.id}) }}" 
                    class="bg-gray-900 text-white px-3 py-1 rounded text-sm">
                    PDF
                    </a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="text-center text-gray-400 py-8">
                    Aucune attribution pour le moment
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Statistiques annuelles #}
<div class="grid grid-cols-3 gap-6 mt-6">
    <div class="bg-white rounded-xl shadow p-6">
        <h2 class="text-lg font-bold mb-4">Attributions par mois ({{ "now"|date('Y') }})</h2>
        <canvas id="monthlyChart"></canvas>
    </div>
<div class="bg-white rounded-xl shadow p-6">
        <h2 class="text-lg font-bold mb-4">Répartition du matériel par statut</h2>
        <canvas id="statusChart"></canvas>
    </div>
    <div class="bg-white rounded-xl shadow p-6">
        <h2 class="text-lg font-bold mb-4">Assets ajoutés par mois ({{ "now"|date('Y') }})</h2>
        <canvas id="assetsChart"></canvas>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
    new Chart(monthlyCtx, {
        type: 'bar',
        data: {
            labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Jun', 'Jul', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'],
            datasets: [{
                label: 'Attributions',
                data: {{ monthlyStats|json_encode|raw }},
                backgroundColor: 'rgba(17, 24, 39, 0.8)',
                borderRadius: 5,
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } }
        }
    });

    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
        type: 'doughnut',
        data: {
            labels: ['Disponible', 'Attribué', 'Maintenance', 'Perdu', 'Rebut'],
            datasets: [{
                data: [
                    {{ statusStats.available }},
                    {{ statusStats.assigned }},
                    {{ statusStats.maintenance }},
                    {{ statusStats.lost }},
                    {{ statusStats.retired }}
                ],
                backgroundColor: ['#10b981', '#3b82f6', '#f97316', '#ef4444', '#6b7280'],
            }]
        },
        options: { responsive: true }
    });
    const assetsCtx = document.getElementById('assetsChart').getContext('2d');
new Chart(assetsCtx, {
    type: 'line',
    data: {
        labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Jun', 'Jul', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'],
        datasets: [{
            label: 'Assets ajoutés',
            data: {{ monthlyAssets|json_encode|raw }},
            borderColor: 'rgba(17, 24, 39, 0.8)',
            backgroundColor: 'rgba(17, 24, 39, 0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } }
    }
});
</script>
{% endblock %}