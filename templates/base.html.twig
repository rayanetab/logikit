<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LogiKit{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

    <div class="flex h-screen">

        {# Sidebar #}
        <div class="w-64 bg-gray-900 text-white flex flex-col">
            <div class="p-6">
                <h1 class="text-2xl font-bold">LogiKit</h1>
                <p class="text-gray-400 text-sm">Asset Management</p>
            </div>
            <nav class="flex-1 px-4">
                <a href="/dashboard" class="flex items-center px-4 py-3 rounded-lg mb-1 hover:bg-gray-700 text-white">
                    Dashboard
                </a>

                {% if is_granted('ROLE_USER') %}
                <a href="/asset" class="flex items-center px-4 py-3 rounded-lg mb-1 hover:bg-gray-700 text-white">
                    Assets Inventory
                </a>
                <a href="/consumable" class="flex items-center px-4 py-3 rounded-lg mb-1 hover:bg-gray-700 text-white">
                    Consumables
                </a>
                <a href="/assignment" class="flex items-center px-4 py-3 rounded-lg mb-1 hover:bg-gray-700 text-white">
                    Assignments
                </a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                <a href="/user" class="flex items-center px-4 py-3 rounded-lg mb-1 hover:bg-gray-700 text-white">
                    Users
                </a>
                <a href="/history" class="flex items-center px-4 py-3 rounded-lg mb-1 hover:bg-gray-700 text-white">
                    Audit Logs
                </a>
                {% endif %}
            </nav>
        </div>

        {# Main content #}
        <div class="flex-1 flex flex-col overflow-hidden">
            {# Header #}
            <header class="bg-white shadow px-6 py-4 flex justify-between items-center">
                <input type="text" placeholder="Search assets, employees, serial numbers..." 
                       class="w-96 px-4 py-2 border rounded-lg text-gray-600">
                <div class="flex items-center gap-4">
                    <span class="text-gray-600">{{ app.user ? app.user.email : '' }}</span>
                    <a href="/logout" class="text-red-500 hover:text-red-700">Logout</a>
                </div>
            </header>

            {# Page content #}
            <main class="flex-1 overflow-y-auto p-6">
                {% block body %}{% endblock %}
            </main>
        </div>

    </div>

</body>
</html>