{% extends 'base.html.twig' %}

{% block title %}Recherche - LogiKit{% endblock %}

{% block body %}
<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Résultats de recherche</h1>
    <p class="text-gray-500">Résultats pour : <strong>{{ query }}</strong></p>
</div>

{# Assets trouvés #}
<div class="bg-white rounded-xl shadow p-6 mb-6">
    <h2 class="text-lg font-bold mb-4">💻 Matériel ({{ assets|length }})</h2>
    {% if assets|length > 0 %}
    <table class="w-full">
        <thead>
            <tr class="text-left text-gray-400 text-sm border-b">
                <th class="pb-3">MARQUE / MODÈLE</th>
                <th class="pb-3">NUMÉRO DE SÉRIE</th>
                <th class="pb-3">STATUT</th>
                <th class="pb-3">ACTION</th>
            </tr>
        </thead>
        <tbody>
            {% for asset in assets %}
            <tr class="border-b hover:bg-gray-50">
                <td class="py-4 font-medium">{{ asset.brand }} {{ asset.model }}</td>
                <td class="py-4">
                    <span class="bg-gray-100 px-2 py-1 rounded text-sm">
                        {{ asset.serialNumber }}
                    </span>
                </td>
                <td class="py-4">
                    <span class="px-3 py-1 rounded-full text-sm font-medium
                        {% if asset.status == 'available' %}bg-green-100 text-green-800
                        {% elseif asset.status == 'assigned' %}bg-blue-100 text-blue-800
                        {% elseif asset.status == 'maintenance' %}bg-orange-100 text-orange-800
                        {% else %}bg-gray-100 text-gray-800{% endif %}">
                        {{ asset.status }}
                    </span>
                </td>
                <td class="py-4">
                    <a href="{{ path('app_asset_show', {'id': asset.id}) }}" 
                       class="text-blue-600 hover:text-blue-800">Voir</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p class="text-gray-400">Aucun matériel trouvé</p>
    {% endif %}
</div>

{# Users trouvés #}
{% if is_granted('ROLE_ADMIN') %}
<div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-bold mb-4">👤 Utilisateurs ({{ users|length }})</h2>
    {% if users|length > 0 %}
    <table class="w-full">
        <thead>
            <tr class="text-left text-gray-400 text-sm border-b">
                <th class="pb-3">NOM</th>
                <th class="pb-3">EMAIL</th>
                <th class="pb-3">RÔLE</th>
                <th class="pb-3">ACTION</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr class="border-b hover:bg-gray-50">
                <td class="py-4 font-medium">{{ user.prenom }} {{ user.nom }}</td>
                <td class="py-4 text-gray-500">{{ user.email }}</td>
                <td class="py-4">
                    {% for role in user.roles %}
                        {% if role != 'ROLE_USER' %}
                        <span class="px-2 py-1 rounded text-sm
                            {% if role == 'ROLE_ADMIN' %}bg-red-100 text-red-800
                            {% else %}bg-blue-100 text-blue-800{% endif %}">
                            {{ role == 'ROLE_ADMIN' ? 'Admin IT' : 'Manager' }}
                        </span>
                        {% endif %}
                    {% endfor %}
                </td>
                <td class="py-4">
                    <a href="{{ path('app_user_show', {'id': user.id}) }}" 
                       class="text-blue-600 hover:text-blue-800">Voir</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p class="text-gray-400">Aucun utilisateur trouvé</p>
    {% endif %}
</div>
{% endif %}
{% endblock %}