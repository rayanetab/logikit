{% extends 'base.html.twig' %}

{% block title %}Assignments - LogiKit{% endblock %}

{% block body %}
<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Attributions</h1>
        <p class="text-gray-500">Gestion des attributions de matériel</p>
    </div>
    <a href="{{ path('app_assignment_new') }}" class="bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-700">
        + Nouvelle attribution
    </a>
</div>

<div class="bg-white rounded-xl shadow p-6">
    <table class="w-full">
        <thead>
            <tr class="text-left text-gray-400 text-sm border-b">
                <th class="pb-3">EMPLOYÉ</th>
                <th class="pb-3">MATÉRIEL</th>
                <th class="pb-3">NUMÉRO DE SÉRIE</th>
                <th class="pb-3">DATE ATTRIBUTION</th>
                <th class="pb-3">DATE RETOUR</th>
                <th class="pb-3">ACTION</th>
            </tr>
        </thead>
        <tbody>
            {% for assignment in assignments %}
            <tr class="border-b hover:bg-gray-50">
                <td class="py-4">{{ assignment.user ? assignment.user.prenom ~ ' ' ~ assignment.user.nom : '-' }}</td>
                <td class="py-4">{{ assignment.asset ? assignment.asset.brand ~ ' ' ~ assignment.asset.model : 'Consommable' }}</td>
                <td class="py-4">
                    <span class="bg-gray-100 px-2 py-1 rounded text-sm">
                        {{ assignment.asset ? assignment.asset.serialNumber : '-' }}
                    </span>
                </td>
                <td class="py-4 text-gray-500">{{ assignment.assignedAt ? assignment.assignedAt|date('d/m/Y') : '' }}</td>
                <td class="py-4 text-gray-500">{{ assignment.returnedAt ? assignment.returnedAt|date('d/m/Y') : 'Non définie' }}</td>
                <td class="py-4">
                    <a href="{{ path('app_assignment_pdf', {'id': assignment.id}) }}" 
                       class="bg-gray-900 text-white px-3 py-1 rounded text-sm">
                        PDF
                    </a>
                    <a href="{{ path('app_assignment_edit', {'id': assignment.id}) }}" 
                       class="text-gray-600 hover:text-gray-800 ml-2">Modifier</a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="text-center text-gray-400 py-8">
                    Aucune attribution pour le moment
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Pagination #}
{% if totalPages > 1 %}
<div class="flex justify-center gap-2 mt-6">
    {% if currentPage > 1 %}
    <a href="{{ path('app_assignment_index', {'page': currentPage - 1}) }}"
       class="px-4 py-2 bg-white rounded-lg shadow hover:bg-gray-100">
        Précédent
    </a>
    {% endif %}

    {% for i in 1..totalPages %}
    <a href="{{ path('app_assignment_index', {'page': i}) }}"
       class="px-4 py-2 rounded-lg shadow
           {% if i == currentPage %}bg-gray-900 text-white{% else %}bg-white hover:bg-gray-100{% endif %}">
        {{ i }}
    </a>
    {% endfor %}

    {% if currentPage < totalPages %}
    <a href="{{ path('app_assignment_index', {'page': currentPage + 1}) }}"
       class="px-4 py-2 bg-white rounded-lg shadow hover:bg-gray-100">
        Suivant
    </a>
    {% endif %}
</div>
{% endif %}
{% endblock %}