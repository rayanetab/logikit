<form method="post" action="{{ path('app_assignment_delete', {'id': assignment.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette attribution ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ assignment.id) }}">
    <button class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600">
        🗑️ Supprimer
    </button>
</form>